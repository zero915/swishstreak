EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Required for Google Sign-In (OAuth web client ID from Firebase / Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Required for Google Sign-In on Android (OAuth Android client ID, type=1 in google-services.json)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Required for Facebook Sign-In (Facebook App ID)
EXPO_PUBLIC_FACEBOOK_APP_ID=

# WSL/Linux: skip auto-install of React Native DevTools (Chromium shell fails on WSL)
EXPO_UNSTABLE_HEADLESS=1
